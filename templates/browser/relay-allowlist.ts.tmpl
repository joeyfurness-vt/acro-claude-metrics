// Server-side allowlist for browser-pushed metrics. EVERY browser-emitted
// metric must be declared here, with EVERY allowed label value enumerated.
// Unknown metrics, unknown label keys, and unknown label values are dropped.
//
// This is the single defense against cardinality explosion from the browser.
// Do not relax it.

export type RelayMetricSpec = {
  name: string;
  type: 'counter' | 'gauge' | 'histogram';
  help: string;
  labels: Record<string, readonly string[]>;
  buckets?: number[];
};

export const RELAY_ALLOWLIST: RelayMetricSpec[] = [
